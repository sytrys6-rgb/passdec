rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règles pour la collection 'offres'
    match /offres/{offerId} {
      // Autoriser la lecture (get et list) pour tout utilisateur authentifié
      allow read: if request.auth != null;
      
      // Autoriser la création si l'utilisateur est authentifié et que le userId correspond à son UID
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Autoriser la modification et la suppression uniquement par le propriétaire de l'offre
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Règles pour la collection 'users' (profils)
    match /users/{userId} {
      // Tout le monde peut voir les profils (pour afficher le nom du vendeur par exemple)
      allow read: if request.auth != null;
      
      // Seul le propriétaire peut modifier ses propres données
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}