
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profils utilisateurs : Tout utilisateur connecté peut lire, seul le propriétaire ou l'admin peut modifier/supprimer
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == "OvtBOwidg7dc4lHw5rR56yqLlIT2");
    }
    
    // Annonces : Lecture publique autorisée pour le "lèche-vitrine"
    // Création, modification et suppression réservées aux membres ou admins
    match /offres/{offreId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.uid == "OvtBOwidg7dc4lHw5rR56yqLlIT2");
    }

    // Messagerie : Seuls les participants peuvent lire et écrire dans une conversation
    match /conversations/{convId} {
      allow read: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      allow update: if request.auth != null && request.auth.uid in resource.data.participants;
      
      match /messages/{msgId} {
        allow read: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Signalements : Tout utilisateur connecté peut créer, seul l'admin peut lire et modifier
    match /signalements/{sigId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && request.auth.uid == "OvtBOwidg7dc4lHw5rR56yqLlIT2";
    }
    
    // Règle par défaut pour le reste du projet
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
