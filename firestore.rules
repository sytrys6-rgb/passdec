rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Marketplace social robuste : lecture publique des offres, isolation des profils et conversations privées.
     */

    // --- Fonctions Globales ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isParticipant(participants) {
      return isSignedIn() && (request.auth.uid in participants);
    }

    // --- Règles des Collections ---

    /**
     * @description Les utilisateurs gèrent leur propre profil.
     * Lecture autorisée pour tous les connectés pour voir les pseudos des vendeurs.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isOwner(userId);
      allow create, update, delete: if isOwner(userId);
    }

    /**
     * @description Offres publiques lisibles par tous (connectés ou non).
     * Création et modification restreintes au propriétaire.
     */
    match /offres/{offreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Conversations privées restreintes aux participants.
     */
    match /conversations/{conversationId} {
      allow get, list: if isParticipant(resource.data.participants);
      allow create: if isSignedIn() && isParticipant(request.resource.data.participants);
      allow update: if isParticipant(resource.data.participants);
      allow delete: if false;

      match /messages/{messageId} {
        allow get, list: if isParticipant(resource.data.participants);
        allow create: if isSignedIn() && isParticipant(request.resource.data.participants) && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    /**
     * @description Données géographiques en lecture seule.
     */
    match /villes/{villeId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}