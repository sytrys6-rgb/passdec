
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper pour vérifier si l'utilisateur est un administrateur
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Profils utilisateurs
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
    
    // Annonces : LECTURE ET LISTING PUBLICS
    match /offres/{offreId} {
      allow read, list: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Messagerie
    match /conversations/{convId} {
      allow read: if request.auth != null && (request.auth.uid in resource.data.participants || isAdmin());
      allow create, update: if request.auth != null && (request.auth.uid in request.resource.data.participants || isAdmin());
      
      match /messages/{msgId} {
        allow read: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants || isAdmin());
        allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Signalements
    match /signalements/{sigId} {
      allow create: if request.auth != null;
      allow read, update, delete: if isAdmin();
    }
    
    // Règle de sécurité globale par défaut
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
