rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Marketplace sociale football : lecture publique des offres, isolation des profils.
     */

    // --- Fonctions Globales ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Règles des Collections ---

    /**
     * @description Les utilisateurs gèrent leur propre profil.
     * Lecture 'get' autorisée pour voir le nom des vendeurs.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    /**
     * @description Offres publiques lisibles par tous (connectés ou non).
     * Correction : Autorise explicitement get et list.
     */
    match /offres/{offreId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Conversations privées restreintes aux participants.
     */
    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
      }
    }
  }
}