rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Marketplace sociale football : lecture publique des offres, isolation des profils.
     */

    // --- Fonctions Globales ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Règles des Collections ---

    /**
     * @description Les utilisateurs gèrent leur propre profil.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    /**
     * @description Offres de la marketplace.
     * Correction demandée par l'utilisateur pour autoriser le 'list'.
     */
    match /offres/{offreId} {
      // Tous les utilisateurs connectés peuvent lire toutes les offres (get et list)
      allow list, get: if isSignedIn();

      // Création autorisée seulement si l'utilisateur est propriétaire (champ userId)
      allow create: if isSignedIn() 
                    && request.resource.data.userId == request.auth.uid;

      // Modification / suppression uniquement par le propriétaire
      allow update, delete: if isSignedIn() 
                            && resource.data.userId == request.auth.uid;
    }

    /**
     * @description Conversations privées restreintes aux participants.
     */
    match /conversations/{conversationId} {
      allow read, write: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants);
      }
    }
  }
}