rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Règles de sécurité pour le projet pass-dc4-06880870-d7efa
    // Autorise la lecture et l'écriture pour tout utilisateur authentifié.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
