
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profils utilisateurs : Tout utilisateur connecté peut lire, seul le propriétaire peut modifier
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Annonces : Tout utilisateur connecté peut lire et créer, seul l'auteur peut modifier ou supprimer
    match /offres/{offreId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Messagerie : Seuls les participants peuvent lire et écrire dans une conversation
    match /conversations/{convId} {
      allow read, write: if request.auth != null && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participants;
      
      match /messages/{msgId} {
        allow read, write: if request.auth != null && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
      }
    }
    
    // Règle par défaut pour le reste du projet
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
