
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within the application, which can be an individual, a football club, or a supporter club.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "nom": {
          "type": "string",
          "description": "The name of the user or club."
        },
        "role": {
          "type": "string",
          "description": "The user's role (e.g., 'user', 'admin').",
          "enum": ["user", "admin"]
        },
        "typeProfil": {
          "type": "string",
          "description": "The type of user profile (e.g., 'particulier', 'club_foot', 'club_supporter')."
        },
        "ville": {
          "type": "string",
          "description": "The city where the user or club is located."
        },
        "description": {
          "type": "string",
          "description": "A brief description or bio of the user or club."
        },
        "photoUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "favoris": {
          "type": "array",
          "description": "Array of Offer IDs favorited by the user.",
          "items": {
            "type": "string"
          }
        },
        "whatsapp": {
          "type": "string",
          "description": "WhatsApp phone number for contact."
        },
        "emailPublic": {
          "type": "string",
          "description": "Public email address for contact.",
          "format": "email"
        },
        "clubPrefere": {
          "type": "string",
          "description": "The favorite football club for individuals."
        },
        "dateNaissance": {
          "type": "string",
          "format": "date",
          "description": "User's date of birth for age validation."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        },
        "isActive": {
          "type": "boolean",
          "description": "A flag indicating if the user account is currently active."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Indicates if the user is blocked from the platform."
        }
      },
      "required": [
        "id",
        "nom",
        "typeProfil",
        "ville",
        "description",
        "createdAt",
        "isActive"
      ]
    },
    "Offer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Offer",
      "type": "object",
      "description": "Represents an item, service, event, or matching request posted by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Offer entity."
        },
        "typeOffre": {
          "type": "string",
          "description": "The type of offer (e.g., 'vendre', 'echanger', 'evenement', 'matcher')."
        },
        "titre": {
          "type": "string",
          "description": "The title or short summary of the offer."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the offer."
        },
        "ville": {
          "type": "string",
          "description": "The city associated with the offer's location."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the User who created this offer."
        },
        "photos": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of Cloudinary URLs."
        },
        "photoIds": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of Cloudinary Public IDs for deletion."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the offer was created.",
          "format": "date-time"
        },
        "isActive": {
          "type": "boolean",
          "description": "A flag indicating if the offer is currently active."
        }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "participantNames": { "type": "object" },
        "offerId": { "type": "string" },
        "offerTitle": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageAt": { "type": "object" },
        "unreadCount": { "type": "object" },
        "deletedBy": { "type": "array", "items": { "type": "string" }, "description": "Array of user IDs who have hidden this conversation." }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "object" },
        "read": { "type": "boolean" }
      }
    },
    "Signalement": {
      "title": "Signalement",
      "type": "object",
      "description": "Represents a report made by a user against a suspicious offer.",
      "properties": {
        "offreId": { "type": "string" },
        "offreTitre": { "type": "string" },
        "signalePar": { "type": "string" },
        "signaleParNom": { "type": "string" },
        "raison": { "type": "string" },
        "details": { "type": "string" },
        "createdAt": { "type": "object" },
        "statut": { "type": "string", "enum": ["en_attente", "traité", "ignoré"] }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/offres/{offreId}",
        "definition": {
          "entityName": "Offer",
          "schema": { "$ref": "#/backend/entities/Offer" },
          "description": "Public offers."
        }
      },
      {
        "path": "/conversations/{convId}",
        "definition": {
          "entityName": "Conversation",
          "schema": { "$ref": "#/backend/entities/Conversation" },
          "description": "Messaging conversations."
        }
      },
      {
        "path": "/conversations/{convId}/messages/{msgId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Messages within a conversation."
        }
      },
      {
        "path": "/signalements/{sigId}",
        "definition": {
          "entityName": "Signalement",
          "schema": { "$ref": "#/backend/entities/Signalement" },
          "description": "User reports for moderation."
        }
      }
    ]
  }
}
